<?php

/**
 * @file
 * Module hooks for Search API AI PGVector in Backdrop CMS.
 */

/**
 * Implements hook_views_data_alter().
 *
 * Hide the Search API DB views integration when using the pgvector backend
 * for a given index/server (parity with Milvus/Pinecone backends).
 */
function search_api_ai_pgvector_views_data_alter(&$data) {
  if (!function_exists('search_api_index_load_multiple')) {
    return;
  }
  $indexes = search_api_index_load_multiple();
  foreach ($indexes as $index) {
    $server = !empty($index->server) ? search_api_server_load($index->server) : NULL;
    if ($server && isset($server->backend) && $server->backend === 'pgvector') {
      unset($data['search_api_index_' . $index->machine_name]);
    }
  }
}

/**
 * Implements hook_autoload_info().
 */
function search_api_ai_pgvector_autoload_info() {
  return [
    'PgvectorService' => 'includes/service.inc',
  ];
}

/**
 * Implements hook_search_api_service_info().
 */
function search_api_ai_pgvector_search_api_service_info() {
  return [
    'pgvector' => [
      'name'        => t('PostgreSQL + pgvector'),
      'description' => t('PostgreSQL + pgvector backend for Search API AI.'),
      'class'       => 'PgvectorService',
      'file'        => 'includes/service.inc',
    ],
  ];
}
