<?php

/**
 * Implements hook_autoload_info().
 */
function search_api_ai_milvus_autoload_info() {
  return [
    'MilvusService' => 'includes/service.inc',
    'SearchApiAiMilvusVectorClient' => 'includes/SearchApiAiMilvusVectorClient.php',
    "SearchApiAiMilvusV2" => 'includes/SearchApiAiMilvusV2.php',
  ];
}

/**
 * Implements hook_search_api_service_info().
 */
function search_api_ai_milvus_search_api_service_info() {
  return [
    'milvus' => [
      'name' => t('Milvus'),
      'description' => t('Milvus backend for Search API AI.'),
      'class' => 'MilvusService',
      'file' => 'includes/service.inc',
    ],
  ];
}

/**
 * Validation callback for Milvus collection name.
 */
function search_api_ai_milvus_validate_collection_name($element, &$form_state) {
  $value = $element['#value'];
  if (!empty($value) && !preg_match('/^[a-zA-Z0-9_]+$/', $value)) {
    form_error($element, t('Collection name can only contain letters, numbers, and underscores. Hyphens and other special characters are not allowed.'));
  }
}
