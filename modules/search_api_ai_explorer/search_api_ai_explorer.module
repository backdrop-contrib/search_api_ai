<?php

require_once backdrop_get_path('module', 'search_api_ai') . '/includes/SearchApiAiBackend.inc';

/**
 * Implements hook_menu().
 */
function search_api_ai_explorer_menu() {
  $items = [];

  $items['admin/config/openai/search-api-ai-explorer'] = [
    'title' => 'Search API AI Explorer',
    'description' => 'Contains a form where you can run ChatGPT using Search API AI as an embedding backend.',
    'page callback' => 'backdrop_get_form',
    'page arguments' => ['search_api_ai_explorer_search_form'],
    'access arguments' => ['administer site configuration'],
    'parent' => 'admin/config/openai',
  ];

  return $items;
}
/**
 * Build the Search API AI Explorer form.
 */
function search_api_ai_explorer_search_form($form, &$form_state) {
  $form['index'] = [
    '#type' => 'select',
    '#title' => t('Index'),
    '#description' => t('Select the index for the embeddings store.'),
    '#options' => [],
  ];

  // Load all indexes and servers at once.
  $indexes = entity_load_multiple('search_api_index');
  $servers = entity_load_multiple('search_api_server');
  foreach ($indexes as $index) {
    if (empty($index->server)) {
      continue;
    }
    $server = NULL;
    foreach ($servers as $s) {
      if ($s->machine_name == $index->server) {
        $server = $s;
        break;
      }
    }
    if ($server && isset($server->class) && ($server->class == 'pinecone' || $server->class == 'milvus')) {
      $form['index']['#options'][$index->machine_name] = $index->name;
    }
  }
  if (empty($form['index']['#options'])) {
    backdrop_set_message(t('No valid Pinecone search indexes found.'), 'warning');
    $form['index']['#options'] = ['' => t('- No indexes available -')];
  }

  // Add Model dropdown, Chat Temperature, and Max Tokens fields directly after Index
  $models = openai_get_all_chat_models();
  
  // Ensure $models is a flat options array for the select element
  $flat_options = [];
  if (!empty($models) && is_array($models)) {
    foreach ($models as $group_label => $group_items) {
      if (is_array($group_items)) {
        foreach ($group_items as $k => $v) {
          $flat_options[$k] = $v;
        }
      }
      else {
        // In case a provider returned a simple map
        foreach ((array) $models as $k => $v) {
          $flat_options[$k] = $v;
        }
        break;
      }
    }
  }
  
  // Determine default. If the existing default isn't available, pick the first model
  $default_model = 'gpt-3.5-turbo';
  if (!empty($flat_options)) {
    if (!isset($flat_options[$default_model])) {
      reset($flat_options);
      $default_model = key($flat_options);
    }
  }
  else {
    $default_model = 'gpt-3.5-turbo';
  }
  
  $form['model'] = [
    '#type' => 'select',
    '#title' => t('Model'),
    '#options' => $flat_options,
    '#default_value' => $default_model,
    '#description' => t('Select a model from any enabled AI provider. Available models and pricing vary by provider.'),
  ];
  $form['chat_temperature'] = [
    '#type' => 'number',
    '#title' => t('Chat Temperature'),
    '#min' => 0,
    '#max' => 2,
    '#step' => .1,
    '#default_value' => isset($form_state['values']['chat_temperature']) ?
      $form_state['values']['chat_temperature'] : 0.5,
    '#description' => t('Controls randomness. Typical values: 0.0 (deterministic) to 1.0 (creative).'),
  ];
  $form['chat_max_tokens'] = [
    '#type' => 'number',
    '#title' => t('Max Tokens'),
    '#min' => 128,
    '#step' => 1,
    '#default_value' => isset($form_state['values']['chat_max_tokens']) ? $form_state['values']['chat_max_tokens'] : 1024,
    '#description' => t('Maximum number of tokens in the response.'),
  ];

  // Add Score Threshold field
  $form['score_threshold'] = [
    '#type' => 'number',
    '#title' => t('Score Threshold'),
    '#min' => 0,
    '#max' => 1,
    '#step' => 0.01,
    '#default_value' => isset($form_state['values']['score_threshold']) ? $form_state['values']['score_threshold'] : 0.5,
    '#description' => t('Minimum score for a result to be considered relevant (0.0 to 1.0).'),
  ];

  // Load previously stored messages.
  $messages = isset($form_state['storage']['messages']) ? $form_state['storage']['messages'] : [];
  $filtered_messages = [];
  $first_user_found = FALSE;

  // Get the value of the system messages checkbox, default to unchecked.
  $show_system_messages = !empty($form_state['values']['system_messages']);

  foreach ($messages as $msg) {
    // Only include system messages if the checkbox is checked.
    if ($msg['role'] === 'system' && !$show_system_messages) {
      continue;
    }
    if ($msg['role'] === 'user') {
      if (!$first_user_found) {
        $filtered_messages[] = $msg;
        $first_user_found = TRUE; // Only include the first user message
      }
    } elseif ($msg['role'] === 'assistant' || $msg['role'] === 'system') {
      $filtered_messages[] = $msg; // Always include assistant messages, and system if allowed
    }
  }
  $form['messages'] = [
    '#type' => 'markup',
    '#markup' => '<div>' . implode('<br>', array_map(function ($msg) {
        $role = '<strong>' . check_plain(ucfirst($msg['role'])) . ':</strong> ';

        if ($msg['role'] === 'assistant') {
          // ✅ Allow full response with lists
          $content = filter_xss($msg['content'], ['a', 'br', 'strong', 'p', 'ol', 'li']);

          // ✅ Ensure answer is visible
          return $role . '<p>' . nl2br($content) . '</p>';
        } else {
          return $role . '<p>' . check_plain($msg['content']) . '</p>';
        }
      }, $filtered_messages)) . '</div>',
  ];



  // **User Input Field**
  $form['query'] = [
    '#type' => 'textarea',
    '#title' => t('Ask ChatGPT a question'),
    '#required' => TRUE,
  ];

  // **Advanced Options**
  $form['options'] = [
    '#type' => 'fieldset',
    '#title' => t('Advanced options'),
  ];
  $form['options']['system_messages'] = [
    '#type' => 'checkbox',
    '#title' => t('Show system messages'),
  ];
  $form['actions'] = ['#type' => 'actions'];
  $form['actions']['submit'] = [
    '#type' => 'submit',
    '#value' => t('Send'),
  ];

  return $form;
}

/**
 * Extract matches and normalized metadata from any backend.
 */
function search_api_ai_extract_contextual_sources($backend_class, $vector_results, $score_threshold) {
  $sources = [];
  $matches = [];

  // Pinecone: has 'matches' key. Milvus: direct array.
  if (($backend_class === 'pinecone' || $backend_class === 'pinecone_service') && isset($vector_results['matches'])) {
    $matches = $vector_results['matches'];
  }
  elseif ($backend_class === 'milvus' && is_array($vector_results) && !isset($vector_results['matches'])) {
    $matches = $vector_results;
  }

  foreach ($matches as $match) {
    // Use whichever exists, or null if neither.
    $score = isset($match['score']) ? $match['score'] :
      (isset($match['distance']) ? $match['distance'] : null);

    // Skip if no score/distance present, or below threshold.
    if ($score === null || $score < $score_threshold) {
      continue;
    }

  // Metadata: Milvus uses top-level, Pinecone nests.
    $metadata = isset($match['metadata']) ? $match['metadata'] : $match;

    // Entity extraction
   if (!empty($metadata['backdrop_entity_id']) && preg_match('/^entity:([^\/]+)\/(\d+):/', $metadata['backdrop_entity_id'], $m)) {
      $datasource_id = $m[1];
      $item_id = $m[2];
    } elseif (!empty($match['id']) && preg_match('/^entity:([^\/]+)\/(\d+):/', $match['id'], $m)) {
      $datasource_id = $m[1];
      $item_id = $m[2];
    } else {
      $datasource_id = !empty($metadata['entity_type']) ? $metadata['entity_type'] : 'node';
      $item_id = !empty($metadata['nid']) ? $metadata['nid'] : (!empty($metadata['tid']) ? $metadata['tid'] : '');
    }
    if (!$datasource_id || !$item_id) {
      continue;
    }

    $entity = entity_load($datasource_id, $item_id);
    if (!$entity) {
      $sources[] = [
        'error' => t('⚠️ Could not load entity: @datasource/@item_id', [
          '@datasource' => $datasource_id,
          '@item_id' => $item_id,
        ]),
      ];
      continue;
    }

    // Title and snippet
    $title = method_exists($entity, 'label') ? check_plain($entity->label()) :
      (!empty($entity->title) ? check_plain($entity->title) : t('Untitled'));
    $uri = $entity->uri();
    $url = url($uri['path']);
    $snippet = !empty($metadata['content']) ? check_plain(substr($metadata['content'], 0, 500)) : '';

    // Paragraph parent lookup (optional)
    if ($datasource_id === 'paragraphs_item') {
      $query = db_select('field_data_field_paragraphs', 'f')
        ->fields('f', ['entity_id'])
        ->condition('f.field_paragraphs_value', $item_id)
        ->range(0, 1);
      $nid = $query->execute()->fetchField();
      if ($nid) {
        $node = node_load($nid);
        if ($node) {
          $title = check_plain($node->title);
          $url = url($node->uri()['path']);
        } else {
          $sources[] = [
            'error' => t('⚠️ Node @nid could not be loaded for paragraph ID @pid.', [
              '@nid' => $nid,
              '@pid' => $item_id,
            ]),
          ];
          continue;
        }
      } else {
        $sources[] = [
          'error' => t('⚠️ Could not find parent node for paragraph ID @id.', ['@id' => $item_id]),
        ];
        continue;
      }
    }
    elseif ($datasource_id === 'taxonomy_term') {
      $title = check_plain($entity->name);
      $url = url($entity->uri()['path']);
    }

    $sources[] = [
      'datasource_id' => $datasource_id,
      'item_id' => $item_id,
      'entity' => $entity,
      'title' => $title,
      'url' => $url,
      'snippet' => $snippet,
      // You may want to include the raw score/distance for debugging:
      'score' => ($backend_class === 'pinecone' || $backend_class === 'pinecone_service') ? $match['score'] : $match['distance'],
    ];
  }
  return $sources;
}


function search_api_ai_explorer_search_form_submit($form, &$form_state) {
  $index_id = $form_state['values']['index'];
  $query_text = trim($form_state['values']['query']);
  // Load the selected index.
  $indexes = entity_load_multiple('search_api_index');
  $index = NULL;
  foreach ($indexes as $i) {
    if ($i->machine_name == $index_id) {
      $index = $i;
      break;
    }
  }
  if (!$index || !is_object($index)) {
    backdrop_set_message(t('Invalid index selected.'), 'error');
    return;
  }

  // Load the associated server.
  $servers = entity_load_multiple('search_api_server');
  $server = NULL;
  foreach ($servers as $s) {
    if ($s->machine_name == $index->server) {
      $server = $s;
      break;
    }
  }
  if (!$server) {
    backdrop_set_message(t('The selected index does not have a valid server.'), 'error');
    return;
  }

  // Get chat model config
  $chat_model = isset($form_state['values']['model']) ? $form_state['values']['model'] : 'gpt-3.5-turbo';
  $chat_temperature = isset($form_state['values']['chat_temperature']) ? floatval($form_state['values']['chat_temperature']) : 0.4;
  $chat_max_tokens = isset($form_state['values']['chat_max_tokens']) ? intval($form_state['values']['chat_max_tokens']) : 1024;

  // Get the appropriate API client for the selected chat model
  if (function_exists('openai_get_api_for_model')) {
    $openai = openai_get_api_for_model($chat_model, $stripped_chat_model);
    // Use the stripped model ID for the API call (without provider prefix)
    $chat_model_to_use = !empty($stripped_chat_model) ? $stripped_chat_model : $chat_model;
  }
  else {
    // Fallback to OpenAI API directly
    $openai_api_key_name = config_get('openai.settings', 'api_key');
    $openai_api_key = key_get_key_value($openai_api_key_name);
    $openai = new OpenAIApi($openai_api_key);
    $chat_model_to_use = $chat_model;
  }
  
  if (!$openai) {
    backdrop_set_message(t('Unable to get API for chat model @model', ['@model' => $chat_model]), 'error');
    return;
  }

  // Get embedding model from index options, then from server options, then use default
  $embedding_model = 'text-embedding-3-small';
  if (!empty($index->options['embedding_settings']['embeddings_engine'])) {
    $embedding_model = $index->options['embedding_settings']['embeddings_engine'];
  }
  elseif (!empty($server->options['embedding_model'])) {
    $embedding_model = $server->options['embedding_model'];
  }

  // **Generate Embeddings using the embeddings engine**
  try {
    // Create configuration for the embedding engine
    $embedding_configuration = [
      'embeddings_engine' => $embedding_model,
      'embeddings_engine_configuration' => ['dimension' => 1536], // Default dimension
    ];

    // Load the embedding engine
    $embedding_engine = search_api_ai_load_embeddings_engine($embedding_configuration);

    if (!$embedding_engine) {
      throw new Exception('Failed to load embedding engine.');
    }

    // Create the embedding for the user query
    $embedding_vector = $embedding_engine->generateEmbeddings($query_text);

    if (!$embedding_vector) {
      throw new Exception('Error retrieving query embedding.');
    }
  } catch (Exception $e) {
    backdrop_set_message(t('Error generating embeddings: @error', ['@error' => $e->getMessage()]), 'error');
    return;
  }
  // --- Determine backend and perform vector search ---
  $vector_results = [];
  $backend_class = $server->class;

  if ($backend_class === 'pinecone' || $backend_class === 'pinecone_service') {
    $pinecone_service = new PineconeService($server);
    $namespace = trim($pinecone_service->getNamespace($index));
    if (strpos($namespace, ':') === 0) {
      $namespace = substr($namespace, 1);
    }
    if (!$namespace) {
      backdrop_set_message(t('Failed to retrieve namespace for Pinecone.'), 'error');
      return;
    }
    $query_options = [
      'vector' => $embedding_vector,
      'top_k' => 8,
      'namespace' => $namespace,
      'include_metadata' => TRUE,
    ];
    $client = new SearchApiAiPineconeVectorClient($server->options);
    try {
      $vector_results = $client->query($query_options);
      if (empty($vector_results['matches'])) {
        backdrop_set_message(t('No relevant results found in Pinecone.'), 'warning');
        return;
      }
    } catch (Exception $e) {
      backdrop_set_message(t('Error querying Pinecone: @error', ['@error' => $e->getMessage()]), 'error');
      return;
    }
  }
  elseif ($backend_class === 'milvus') {
    $milvus_service = new MilvusService($server);
    $collection = $milvus_service->getCollection($index);
    if (!$collection) {
      backdrop_set_message(t('Failed to retrieve collection for Milvus.'), 'error');
      return;
    }
    $database = isset($server->options['database']) ? $server->options['database'] : 'default';
    $query_options = [
      'vector' => $embedding_vector,
      'top_k' => 8,
      'collection' => $collection,
      'database' => $database,
      'output_fields' => [
        'content',
        'nid',
        'title',
        'backdrop_entity_id',
        'backdrop_long_id',
        'field_name',
        'server_id',
        'index_id'
      ],
    ];
    // Pass server options directly to the client
    $client = new SearchApiAiMilvusVectorClient($server->options);
    if (!$client) {
      backdrop_set_message(t('Milvus client is not initialized.'), 'error');
      return;
    }
    try {
      $vector_results = $client->query($query_options);
      if (empty($vector_results)) {
        backdrop_set_message(t('No relevant results found in Milvus.'), 'warning');
        return;
      }
    } catch (Exception $e) {
      backdrop_set_message(t('Error querying Milvus: @error', ['@error' => $e->getMessage()]), 'error');
      return;
    }
  }
  else {
    backdrop_set_message(t('This backend is not supported for vector search.'), 'error');
    return;
  }

  // --- Process Results and Add to Messages ---
  $score_threshold = isset($form_state['values']['score_threshold']) ? floatval($form_state['values']['score_threshold']) : 0.5;
  $sources = search_api_ai_extract_contextual_sources($backend_class, $vector_results, $score_threshold);

  $document_links = [];
  $formatted_sources = [];
  foreach ($sources as $src) {
    if (!empty($src['error'])) {
      backdrop_set_message($src['error'], 'warning');
      continue;
    }
    $formatted_sources[] = "<a href='{$src['url']}'>{$src['title']}</a>: {$src['snippet']}";
    $document_links[] = "<a href='{$src['url']}'>{$src['title']}</a>";
  }

  // Compose chat prompt and finish as before...
  $messages[] = ['role' => 'user', 'content' => $query_text];
  // Initialize AI Messages (only once!)
  $messages = [
    [
      'role' => 'system',
      'content' => "You are an AI Agent embedded in a Backdrop CMS website.
                  Your job is to answer user questions using a local vector database through the RAG tool.
                  You must only use content from this site — external sources are not allowed.
                  Do not fabricate or guess any information or links.
                  When a user submits a query:
                  Search the vector database for up to 5 relevant nodes, unless the question is unusually complex.
                  Use only the retrieved content to generate your answer.
                  Limit your response to 5 sentences or less if possible.",
    ],
  ];

  // Add the user/context message (do NOT overwrite $messages!)
  if (!empty($formatted_sources)) {
    $combined_context = implode("\n\n", array_map('strip_tags', $formatted_sources));
    $messages[] = [
      'role' => 'user',
      'content' => "Here is relevant source content:\n\n$combined_context\n\nUsing only the information above, answer the question: $query_text",
    ];
  } else {
    $messages[] = [
      'role' => 'user',
      'content' => $query_text,
    ];
  }


  // **Call AI Chat Model**
  try {
    $ai_response = $openai->chat($chat_model_to_use, $messages, $chat_temperature, $chat_max_tokens);
    if (!empty($ai_response)) {
      $ai_response_text = trim($ai_response);
    } else {
      $ai_response_text = 'No response provided.';
    }
    $ai_response_text = preg_replace('/<a href=[^>]+>([^<]+)<\/a>/', '$1', $ai_response_text);
    $document_links = array_unique($document_links);
    if (!empty($document_links)) {
      $ai_response_text .= "<br><br><strong>For more detailed information, you can refer to this content:</strong><ol>";
      foreach ($document_links as $link) {
        $ai_response_text .= "<li>$link</li>";
      }
      $ai_response_text .= "</ol>";
    }
    $messages[] = [
      'role' => 'assistant',
      'content' => $ai_response_text,
    ];
  } catch (Exception $e) {
    backdrop_set_message(t('AI chat exception: @error', ['@error' => $e->getMessage()]), 'error');
    return;
  }

  $show_system_messages = !empty($form_state['values']['system_messages']);
  if (!$show_system_messages) {
    $messages = array_filter($messages, function ($msg) {
      return $msg['role'] !== 'system';
    });
  }
  $form_state['storage']['messages'] = $messages;
  $form_state['rebuild'] = TRUE;
}
