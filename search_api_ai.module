function search_api_ai_search_api_processor_info() {
  return [
    'database_boost_by_ai_search' => [
      'name' => t('Boost Database by AI Search'),
      'description' => t('This combines results from the AI Search (Vector Database) with the traditional database, both finding results that would otherwise not be found due to lack of keyword match, as well as vastly improving the relevance of the top results. It prepends the results from the AI Search into the database results ready for and respecting any filtering applied to this index (such as filters, exposed filters, or facets).'),
      'class' => 'DatabaseBoostByAiSearch',
    ],
  ];
}


function search_api_ai_search_api_db_query_alter(SelectQueryInterface $query, SearchApiQueryInterface $search_api_query) {
  $item_ids = $search_api_query->getOption('ai_search_ids');
  if (!empty($item_ids)) {
    DatabaseBoostByAiSearch::queryAlter($query, $item_ids);
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function search_api_ai_form_search_api_admin_add_index_submit($form, &$form_state) {
  // Get the embedding settings from the form
  $embedding_settings = [
    'embeddings_engine' => $form_state['values']['embeddings_engine'],
    'embeddings_engine_configuration' => [
      'dimension' => $form_state['values']['embeddings_engine_configuration']['dimension'],
    ],
  ];

  // Add the settings to the index options
  if (isset($form_state['values']['options'])) {
    $form_state['values']['options']['embedding_settings'] = $embedding_settings;
  }
  else {
    $form_state['values']['options'] = ['embedding_settings' => $embedding_settings];
  }
}

