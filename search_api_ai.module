/**
 * AJAX Callback to update embedding dimension dynamically.
 */
function search_api_ai_update_embedding_dimension($form, &$form_state) {
  $selected_engine = $form_state['values']['embedding_settings']['embeddings_engine'] ?? NULL;
  $dimension_value = 768; // Default

  // Load available embedding engines.
  $all_engines = module_invoke_all('embedding_engine_info');
  if ($selected_engine && isset($all_engines[$selected_engine])) {
    $engine_class = $all_engines[$selected_engine]['class'];
    if (class_exists($engine_class)) {
      try {
        // Only the API key is needed from global config now.
        $api_key_name = config_get('openai.settings', 'api_key');
        $api_key = key_get_key_value($api_key_name);
        if (!$api_key) {
          throw new Exception('OpenAI API key is missing.');
        }
        $client = new OpenAIApi($api_key);

        // Engine config is per-index, not global anymore.
        // If you need settings, pull from $form_state or pass [].
        $engine_instance = new $engine_class([], $client);

        if (method_exists($engine_instance, 'getDimension')) {
          $dimension_value = $engine_instance->getDimension();
        }
      } catch (Exception $e) {
        watchdog('search_api_ai', 'Failed to update dimension for @engine: @message', [
          '@engine' => $selected_engine,
          '@message' => $e->getMessage(),
        ], WATCHDOG_ERROR);
      }
    }
  }

  $form['embedding_settings']['embeddings_engine_configuration']['dimension']['#value'] = $dimension_value;
  return $form['embedding_settings']['embeddings_engine_configuration'];
}

function search_api_ai_form_search_api_admin_index_edit_alter(&$form, &$form_state) {
  $form['#submit'][] = 'search_api_ai_embedding_settings_submit';
  $form['#after_build'][] = 'search_api_ai_embedding_settings_copy_for_save';
}
function search_api_ai_form_search_api_admin_add_index_alter(&$form, &$form_state) {
  $form['#submit'][] = 'search_api_ai_embedding_settings_submit';
  $form['#after_build'][] = 'search_api_ai_embedding_settings_copy_for_save';
}

function search_api_ai_embedding_settings_copy_for_save($form, &$form_state) {
  // Copy top-level embedding_settings into options so Search API will persist it.
  if (!empty($form_state['values']['embedding_settings'])) {
    $form_state['values']['options']['embedding_settings'] = $form_state['values']['embedding_settings'];
  }
  return $form;
}

function search_api_ai_embedding_settings_submit($form, &$form_state) {
  // Ensure again on submit (sometimes values shift during validation steps).
  if (!empty($form_state['values']['embedding_settings'])) {
    $form_state['values']['options']['embedding_settings'] = $form_state['values']['embedding_settings'];
  }
}



/**
 * Submit handler for the embedding engine configuration form.
 */
function search_api_ai_embedding_engine_config_form_submit($form, &$form_state) {
  $selected_engine = $form_state['values']['options']['embeddings_engine'] ??
    '';
  $engine_config = $form_state['values']['options']['embeddings_engine_configuration']
    ?? ['dimension' => 768];

  // Load available embedding engines.
  $all_engines = module_invoke_all('embedding_engine_info');

  if ($selected_engine && isset($all_engines[$selected_engine])) {
    $engine_class = $all_engines[$selected_engine]['class'];

    if (class_exists($engine_class)) {
      try {
        // Retrieve OpenAI API key.
        $api_key_name = config_get('openai.settings', 'api_key');
        $api_key = key_get_key_value($api_key_name);
        if (!$api_key) {
          throw new Exception('OpenAI API key is missing.');
        }

        // Create OpenAI client instance.
        $client = new OpenAIApi($api_key);
        $engine_instance = new $engine_class(config_get('search_api_ai.settings'), $client);

        // Retrieve **clean model name** from the class.
        $model_name = method_exists($engine_instance, 'getModelName')
          ? $engine_instance->getModelName()
          : $selected_engine;

        // Retrieve dimension from the selected engine.
        if (method_exists($engine_instance, 'getDimension')) {
          $engine_config['dimension'] = $engine_instance->getDimension();
        }
      } catch (Exception $e) {
        backdrop_set_message(t('Failed to load embedding engine: @message', [
          '@message' => $e->getMessage(),
        ]), 'error');
        watchdog('search_api_ai', 'Error initializing embedding engine @engine: @message', [
          '@engine' => $selected_engine,
          '@message' => $e->getMessage(),
        ], WATCHDOG_ERROR);
      }
    }
  }

  // Save the configuration using **model name instead of engine ID**.
  config_set('search_api_ai.settings', 'embeddings_engine', $model_name);
  config_set('search_api_ai.settings', 'embeddings_engine_configuration', $engine_config);

  backdrop_set_message(t('Embedding engine configuration has been saved.'));
}

/**
 * Implements hook_search_api_index_items_alter().
 *
 * Injects OpenAI embeddings into items containing LLM vector fields.
 */
function search_api_ai_search_api_index_items_alter(array &$items, SearchApiIndex $index) {
  global $search_api_ai_vectors;
  if (!isset($search_api_ai_vectors)) $search_api_ai_vectors = [];

  watchdog('search_api_ai', '🔄 Altering index items for @index', [
    '@index' => $index->machine_name
  ], WATCHDOG_NOTICE);

  // Load index options.
  $query = db_select('search_api_index', 's')
    ->fields('s', ['options'])
    ->condition('machine_name', $index->machine_name)
    ->execute()
    ->fetchField();
  if (!$query) {
    watchdog('search_api_ai', "❌ Could not load index configuration.", [], WATCHDOG_ERROR);
    return;
  }
  $index_options = @unserialize($query);
  if (empty($index_options['fields']) || !is_array($index_options['fields'])) {
    watchdog('search_api_ai', "❌ No valid fields found in index configuration.", [], WATCHDOG_ERROR);
    return;
  }

  $embedding_settings = $index_options['embedding_settings'] ?? [];
  if (!is_array($embedding_settings)) $embedding_settings = [];

  // Find the main content field (the one set to llm_vector_embedding).
  $main_content_field = NULL;
  foreach ($index_options['fields'] as $field_name => $field_info) {
    if (!empty($field_info['real_type']) && $field_info['real_type'] === 'llm_vector_embedding') {
      $main_content_field = $field_name;
      break;
    }
  }
  if (!$main_content_field) {
    watchdog('search_api_ai', "❌ No field with llm_vector_embedding found. Nothing to embed.", [], WATCHDOG_ERROR);
    return;
  }

  $contextual_fields = array_diff(array_keys($index_options['fields']), [$main_content_field]);

  // View mode
  $view_mode = 'full';
  if (!empty($index_options['data_alter_callbacks']['search_api_alter_add_viewed_entity']['settings']['mode'])) {
    $view_mode = $index_options['data_alter_callbacks']['search_api_alter_add_viewed_entity']['settings']['mode'];
  }
  $expected_dimension = $embedding_settings['embeddings_engine_configuration']['dimension'] ?? 1536;

  foreach ($items as $id => $item) {
    $entity_type = NULL; $entity_id = NULL; $entity = NULL;
    if (is_string($id) && strpos($id, '/') !== FALSE) {
      list($entity_type, $entity_id) = explode('/', $id, 2);
      $entity = entity_load($entity_type, $entity_id);
    }
    elseif (is_object($item)) {
      if (isset($item->nid))            { $entity_type = 'node';             $entity_id = $item->nid; $entity = $item; }
      elseif (isset($item->tid))        { $entity_type = 'taxonomy_term';    $entity_id = $item->tid; $entity = $item; }
      elseif (isset($item->item_id))    { $entity_type = 'paragraphs_item';  $entity_id = $item->item_id; $entity = $item; }
    }
    if (!$entity || !$entity_type || !$entity_id) {
      watchdog('search_api_ai', '⚠️ Could not determine or load entity for ID: @id', ['@id' => $id], WATCHDOG_WARNING);
      continue;
    }

    // Title for citation/metadata
    $title = '';
    if ($entity_type == 'node' && !empty($entity->title)) {
      $title = $entity->title;
    }
    elseif ($entity_type == 'taxonomy_term' && !empty($entity->name)) {
      $title = $entity->name;
    }
    elseif ($entity_type == 'paragraphs_item' && !empty($entity->title)) {
      $title = $entity->title;
    }

    // Contextual/filterable metadata dynamically:
    $context_metadata = ['title' => $title];
    foreach ($contextual_fields as $field_name) {
      if (!empty($entity->{$field_name})) {
        $value = $entity->{$field_name};
        if (is_array($value) && isset($value['und']) && is_array($value['und'])) {
          $tids = [];
          $labels = [];
          foreach ($value['und'] as $item) {
            if (!empty($item['tid'])) {
              $tids[] = $item['tid'];
              $term = taxonomy_term_load($item['tid']);
              if ($term && !empty($term->name)) {
                $labels[] = $term->name;
              }
            }
          }
          $context_metadata[$field_name . '_tids'] = $tids;
          $context_metadata[$field_name . '_names'] = $labels;
        }
        else {
          $context_metadata[$field_name] = $value;
        }
      }
    }

    // --- Store both search_api_url (alias) and url (absolute) ---
    $relative_url = '';
    $absolute_url = '';
    if ($entity_type === 'node') {
      $internal_path = "node/$entity_id";
      $path = path_load(['source' => $internal_path]);
      $alias = !empty($path['alias']) ? $path['alias'] : $internal_path;
      $relative_url = $alias;
      $absolute_url = url($internal_path, ['absolute' => TRUE]);
    }
    elseif ($entity_type === 'taxonomy_term') {
      $internal_path = "taxonomy/term/$entity_id";
      $path = path_load(['source' => $internal_path]);
      $alias = !empty($path['alias']) ? $path['alias'] : $internal_path;
      $relative_url = $alias;
      $absolute_url = url($internal_path, ['absolute' => TRUE]);
    }
    $context_metadata['search_api_url'] = $relative_url;
    $context_metadata['url'] = $absolute_url;

    // Main content extraction
    $cleaned_text = '';
    if ($main_content_field == 'search_api_viewed') {
      $view = entity_view($entity, $view_mode);
      $cleaned_text = trim(strip_tags(render($view)));
    }
    else {
      if (!empty($entity->{$main_content_field})) {
        $field_value = $entity->{$main_content_field};
        if (is_array($field_value)) {
          foreach ($field_value as $langcode => $items) {
            foreach ($items as $item_value) {
              if (!empty($item_value['value'])) {
                $cleaned_text .= "\n" . trim(strip_tags($item_value['value']));
              }
            }
          }
        } elseif (is_string($field_value)) {
          $cleaned_text = trim(strip_tags($field_value));
        }
      }
    }
    if (empty($cleaned_text)) {
      watchdog('search_api_ai', "⚠️ No main content to embed for $entity_type/$entity_id", [], WATCHDOG_WARNING);
      continue;
    }

    // Chunk/embed main content.
    $vectors = search_api_ai_convert_embedding($cleaned_text, 'string', 'llm_vector_embedding', $embedding_settings, $main_content_field);

    foreach ($vectors as $chunk_idx => $entry) {
      $chunk_vector = $entry['vector'];
      $chunk_text = $entry['chunk'];
      if (!is_array($chunk_vector) || count($chunk_vector) !== (int)$expected_dimension) {
        watchdog('search_api_ai', "❌ Invalid vector size for $main_content_field in entity $entity_type/$entity_id (chunk $chunk_idx)", [], WATCHDOG_ERROR);
        continue;
      }
      $search_api_ai_vectors[] = array_merge([
        'entity_type' => $entity_type,
        'entity_id'   => $entity_id,
        'field_name'  => $main_content_field,
        'chunk_index' => $chunk_idx,
        'vector'      => $chunk_vector,
        'content'     => $chunk_text,
      ], $context_metadata);
    }
  }

  watchdog('search_api_ai', '✅ Finished altering index items for @index', [
    '@index' => $index->machine_name
  ], WATCHDOG_NOTICE);
}

