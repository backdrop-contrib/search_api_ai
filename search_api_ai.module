/**
 * Implements hook_search_api_data_type_info().
 */
function search_api_ai_search_api_data_type_info() {
  return array(
    'llm_vector_embedding' => array(
      'name' => t('Embeddings'),
      'fallback' => 'string',
      'conversion callback' => 'search_api_ai_convert_embedding',
    ),
  );
}

/**
 * Default embedding dimension when nothing else is available.
 */
function search_api_ai_get_embedding_dimension() {
  return 1536;
}

function search_api_ai_convert_embedding($value, $original_type, $type, array $embedding_settings, $field_name = 'unknown_field', $server = NULL) {
  if ($type !== 'llm_vector_embedding' || !is_string($value)) {
    watchdog('search_api_ai', "❌ Bad call: type=$type, is_string=" . (is_string($value) ? 'yes' : 'no'), [], WATCHDOG_WARNING);
    return [];
  }

  $prepared_text = StringHelper::prepareText($value);
  if (empty($prepared_text)) {
    watchdog('search_api_ai', "⚠️ Skipping empty text for field: $field_name", [], WATCHDOG_WARNING);
    return [];
  }

  // Prefer server-level chunking, otherwise index-provided.
  if ($server) {
    $embedding_strategy = $server->options['embedding_strategy'] ?? [];
  }
  else {
    $embedding_strategy = $embedding_settings['embedding_strategy'] ?? [];
  }
  $chunk_size    = !empty($embedding_strategy['chunk_size']) ? (int) $embedding_strategy['chunk_size'] : 500;
  $chunk_overlap = !empty($embedding_strategy['chunk_overlap']) ? (int) $embedding_strategy['chunk_overlap'] : 100;
  $chunks = TextChunker::chunkText($prepared_text, $chunk_size, $chunk_overlap);

  $config = search_api_ai_get_embedding_engine_config($embedding_settings);
  $model = $config['engine'];
  $expected_dimension = $config['dimension'];

  if (empty($model)) {
    watchdog('search_api_ai', "❌ No valid embeddings model set.", [], WATCHDOG_ERROR);
    return [];
  }

  // Get the embedding engine instance based on the selected model
  // The model format can be: provider/modelname (e.g., "ollama/nomic-embed-text") or just modelname (e.g., "text-embedding-3-small")
  $engine_instance = NULL;
  $provider = NULL;

  watchdog('search_api_ai', '🔍 Looking up engine for model: @model', ['@model' => $model], WATCHDOG_DEBUG);

  // Check if model has a provider prefix (e.g., "ollama/", "openai/")
  if (strpos($model, '/') !== FALSE) {
    list($provider, $model_name) = explode('/', $model, 2);
    watchdog('search_api_ai', '🔍 Extracted provider: @provider, model_name: @name', ['@provider' => $provider, '@name' => $model_name], WATCHDOG_DEBUG);
  }

  // Only load engine for non-OpenAI providers (Ollama, OpenRouter)
  // OpenAI models will use the API directly
  if ($provider && $provider !== 'openai') {
    $engine_info = search_api_ai_embedding_engine_info();
    watchdog('search_api_ai', '🔍 Available engines: @engines', ['@engines' => print_r(array_keys($engine_info), TRUE)], WATCHDOG_DEBUG);

    // Map provider names to engine IDs
    $provider_to_engine = [
      'ollama' => 'ollama',
      'openrouter' => 'openrouter',
    ];

    $engine_id = isset($provider_to_engine[$provider]) ? $provider_to_engine[$provider] : $provider;
    watchdog('search_api_ai', '🔍 Mapped to engine_id: @id', ['@id' => $engine_id], WATCHDOG_DEBUG);

    if (isset($engine_info[$engine_id])) {
      $info = $engine_info[$engine_id];
      $engine_class = $info['class'];

      watchdog('search_api_ai', '🔍 Found engine class: @class', ['@class' => $engine_class], WATCHDOG_DEBUG);

      // Load the file if specified
      if (!empty($info['file']) && !empty($info['module'])) {
        $module_path = backdrop_get_path('module', $info['module']);
        require_once BACKDROP_ROOT . '/' . $module_path . '/' . $info['file'];
        watchdog('search_api_ai', '✅ Loaded file: @file', ['@file' => $module_path . '/' . $info['file']], WATCHDOG_DEBUG);
      }

      if (class_exists($engine_class)) {
        // Extract just the model name without provider prefix
        $model_name_only = strpos($model, '/') !== FALSE ? explode('/', $model, 2)[1] : $model;
        watchdog('search_api_ai', '✅ Instantiating @class with model: @model', ['@class' => $engine_class, '@model' => $model_name_only], WATCHDOG_DEBUG);
        $engine_instance = new $engine_class(['model_id' => $model_name_only]);
      } else {
        watchdog('search_api_ai', '❌ Class @class does not exist', ['@class' => $engine_class], WATCHDOG_ERROR);
      }
    } else {
      watchdog('search_api_ai', '❌ No engine info found for engine_id: @id', ['@id' => $engine_id], WATCHDOG_ERROR);
    }
  }

  // Use OpenAI API for OpenAI models or as fallback
  if (!$engine_instance) {
    watchdog('search_api_ai', '⚠️ Using OpenAI API fallback for model: @model', ['@model' => $model], WATCHDOG_WARNING);
    $openai_config = config('openai.settings');
    $api_key_name  = $openai_config->get('api_key');
    $api_key       = key_get_key_value($api_key_name);
    $openai_api    = new OpenAIApi($api_key);
  }

  $chunked_vectors = [];
  foreach ($chunks as $i => $chunk) {
    $chunk_clean = StringHelper::prepareText($chunk);
    if (empty($chunk_clean)) continue;
    try {
      if ($engine_instance) {
        $vector = $engine_instance->generateEmbeddings($chunk_clean);
      }
      else {
        $vector = $openai_api->embedding($chunk_clean, $model);
      }

      if (!is_array($vector) || count($vector) !== (int) $expected_dimension) {
        watchdog('search_api_ai', "❌ Invalid chunk vector size for $field_name: Expected $expected_dimension, got " . (is_array($vector) ? count($vector) : gettype($vector)), [], WATCHDOG_ERROR);
        continue;
      }
      $chunked_vectors[] = [
        'vector' => $vector,
        'chunk'  => $chunk,
      ];
    } catch (Exception $e) {
      watchdog('search_api_ai', "❌ Embedding API error for $field_name: " . $e->getMessage(), [], WATCHDOG_ERROR);
    }
  }
  if (empty($chunked_vectors)) {
    watchdog('search_api_ai', "⚠️ No valid vectors generated for $field_name", [], WATCHDOG_WARNING);
  }
  return $chunked_vectors;
}

/**
 * Get embedding model and dimension from Search API AI index options.
 */
function search_api_ai_get_embedding_engine_config(array $embedding_settings) {
  if (empty($embedding_settings['embeddings_engine'])) {
    throw new Exception('No embedding engine set in index options.');
  }
  $model = $embedding_settings['embeddings_engine'];
  $dimension = isset($embedding_settings['embeddings_engine_configuration']['dimension'])
    ? (int) $embedding_settings['embeddings_engine_configuration']['dimension']
    : 1536;

  return [
    'engine' => $model,
    'dimension' => $dimension,
  ];
}


/**
 * Implements hook_form_alter().
 *
 * Unified handler for:
 *   - search_api_admin_add_server
 *   - search_api_admin_server_edit
 *   - search_api_server_edit_form (alt ID some installs use)
 *   - search_api_admin_add_index
 *   - search_api_admin_index_edit
 */
function search_api_ai_form_alter(&$form, &$form_state, $form_id) {

  // ===== Server ADD/EDIT: place embedding_strategy INSIDE options[form] =====
  if (in_array($form_id, ['search_api_admin_add_server', 'search_api_admin_server_edit', 'search_api_server_edit_form'], TRUE)) {

    // Standardize weights for top-level bits (not strictly required).
    if (isset($form['name']))         { $form['name']['#weight'] = 0; }
    if (isset($form['machine_name'])) { $form['machine_name']['#weight'] = 1; }
    if (isset($form['enabled']))      { $form['enabled']['#weight'] = 2; }
    if (isset($form['description']))  { $form['description']['#weight'] = 3; }
    if (isset($form['class']))        { $form['class']['#weight'] = 5; }
    if (isset($form['options']))      { $form['options']['#weight'] = 6; }
    if (isset($form['submit']))       { $form['submit']['#weight'] = 7; }

    // Ensure the expected structure exists for add/edit:
    if (!isset($form['options'])) {
      $form['options'] = ['#type' => 'fieldset', '#tree' => TRUE];
    }
    if (!isset($form['options']['form'])) {
      // Service classes put their config here; ensure the container exists so our fields get into options[form].
      $form['options']['form'] = [];
    }

    // Defaults from saved server on edit or any posted values.
    $server   = isset($form_state['server']) ? $form_state['server'] : NULL;
    $settings = [];
    if ($server && !empty($server->options['embedding_strategy'])) {
      $settings = $server->options['embedding_strategy'];
    }
    elseif (!empty($form_state['values']['options']['form']['embedding_strategy'])) {
      $settings = $form_state['values']['options']['form']['embedding_strategy'];
    }

    // Place our fieldset *inside* options[form] so add_server_submit picks it up.
    $form['options']['form']['embedding_strategy'] = [
      '#type'   => 'fieldset',
      '#title'  => t('Embedding Strategy Configuration'),
      '#tree'   => TRUE,
      '#weight' => 50, // after most service options
    ];
    $form['options']['form']['embedding_strategy']['chunk_size'] = [
      '#type' => 'textfield',
      '#title' => t('Maximum chunk size (tokens)'),
      '#default_value' => $settings['chunk_size'] ?? 500,
      '#description' => t('Maximum chunk size allowed when breaking up larger content.'),
    ];
    $form['options']['form']['embedding_strategy']['chunk_overlap'] = [
      '#type' => 'textfield',
      '#title' => t('Minimum chunk overlap (tokens)'),
      '#default_value' => $settings['chunk_overlap'] ?? 100,
      '#description' => t('Number of tokens to overlap between chunks.'),
    ];
    // After you create $form['options']['form']['embedding_strategy']...
    $form['options']['form']['embedding_strategy']['how_to'] = [
      '#type'        => 'fieldset',
      '#title'       => t('How to select your chunk size'),
      '#tree'        => TRUE,
      '#collapsible' => TRUE,
      '#collapsed'   => TRUE,
      '#weight'      => 60,
    ];

    $form['options']['form']['embedding_strategy']['how_to']['body'] = [
      '#type'   => 'item',
      '#markup' => '
    <p><strong>What this does:</strong> This setting determines the number of tokens in each text chunk that will be stored in the vector database. Proper configuration is crucial for optimizing search accuracy and database performance.</p>

    <p><em>You should do your own research and come to your own conclusions, but here is some general AI-generated advice:</em></p>

    <h3>Smaller Chunk Size (e.g., 50–100 tokens)</h3>
    <ul>
      <li><strong>Use cases:</strong> Highly granular search where detailed segments must be retrievable.</li>
      <li><strong>Advantages:</strong> Increases precision; easier to find specific phrases or concepts.</li>
      <li><strong>Disadvantages:</strong> More chunks → larger DB size and potentially more processing.</li>
    </ul>

    <h3>Larger Chunk Size (e.g., 200–500 tokens)</h3>
    <ul>
      <li><strong>Use cases:</strong> General search where broader segments are fine.</li>
      <li><strong>Advantages:</strong> Fewer chunks → better storage and search throughput.</li>
      <li><strong>Disadvantages:</strong> Lower accuracy for very specific queries.</li>
    </ul>

    <h3>Balance Between Size and Performance</h3>
    <p>Aim for a balance that fits your content and queries. Consider the nature of the text and typical search behavior.</p>

    <h3>Additional considerations</h3>
    <ul>
      <li><strong>Text complexity:</strong> Dense/technical text often benefits from smaller chunks.</li>
      <li><strong>Search behavior:</strong> If users hunt for fine details, prefer smaller chunks; for broad recall, larger can work.</li>
      <li><strong>System resources:</strong> Larger chunks reduce DB load but lower granularity—pick a size your infra handles well.</li>
    </ul>
  ',
    ];


    // Validate the two fields (values live at options][form][embedding_strategy][...]).
    $v = &$form_state['values'];
    $path = ['options','form','embedding_strategy'];
    $cs = _search_api_ai_nested_value($v, array_merge($path, ['chunk_size']));
    $co = _search_api_ai_nested_value($v, array_merge($path, ['chunk_overlap']));

    // Attach a lightweight validate to guard numbers.
    $form['#validate'][] = 'search_api_ai_form_server_embedding_strategy_validate';
  }

  // ===== Index ADD/EDIT: embedding engine lives per-index =====
  if (in_array($form_id, ['search_api_admin_index_edit', 'search_api_admin_add_index'], TRUE)) {
    if (isset($form['name']))         { $form['name']['#weight'] = 10; }
    if (isset($form['machine_name'])) { $form['machine_name']['#weight'] = 20; }
    if (isset($form['item_type']))    { $form['item_type']['#weight'] = 30; }
    if (isset($form['datasource']))   { $form['datasource']['#weight'] = 40; }
    if (isset($form['enabled']))      { $form['enabled']['#weight'] = 50; }
    if (isset($form['description']))  { $form['description']['#weight'] = 60; }
    if (isset($form['server']))       { $form['server']['#weight'] = 70; }
    if (isset($form['read_only']))    { $form['read_only']['#weight'] = 90; }
    if (isset($form['options']))      { $form['options']['#weight'] = 100; }
    if (isset($form['submit']))       { $form['submit']['#weight'] = 110; }

    $index    = isset($form_state['index']) ? $form_state['index'] : NULL;
    $settings = [];
    if ($index && !empty($index->options['embedding_settings'])) {
      $settings = $index->options['embedding_settings'];
    }
    elseif (!empty($form_state['values']['embedding_settings'])) {
      $settings = $form_state['values']['embedding_settings'];
    }

    $selected_engine = $settings['embeddings_engine'] ?? '';
    $dimension_value = $settings['embeddings_engine_configuration']['dimension'] ?? 768;

    $all_engines = module_invoke_all('embedding_engine_info');
    $embedding_engines = array_filter($all_engines, function ($engine) {
      return isset($engine['class'])
        && class_exists($engine['class'])
        && ($engine['class'] === 'SearchApiAiEmbeddingsBase' || is_subclass_of($engine['class'], 'SearchApiAiEmbeddingsBase'));
    });

    $options = [];
    foreach ($embedding_engines as $id => $engine) {
      // Use the label from embedding_engine_info() hook instead of instantiating the class
      $options[$id] = isset($engine['label']) ? $engine['label'] : $id;
    }

    // Only show when server class is Milvus or Pinecone.
    $servers = search_api_server_load_multiple(FALSE, ['enabled' => 1]);
    $or_groups = [];
    foreach ($servers as $server_obj) {
      if (in_array(strtolower($server_obj->class), ['milvus', 'pinecone'])) {
        $or_groups[] = [
          ':input[name="server"]' => ['value' => $server_obj->machine_name],
        ];
      }
    }

    $form['embedding_settings'] = [
      '#type'  => 'fieldset',
      '#title' => t('Embedding Settings'),
      '#weight'=> 71,
      '#tree'  => TRUE,
      '#states'=> !empty($or_groups) ? ['visible' => $or_groups] : [],
    ];

    $form['embedding_settings']['embeddings_engine'] = [
      '#type' => 'select',
      '#title' => t('Embedding Engine'),
      '#options' => $options,
      '#default_value' => $selected_engine,
      '#description' => t('Select the embedding engine to use. This needs to match the setting in the Vector database.'),
      '#ajax' => [
        'callback' => 'search_api_ai_update_embedding_dimension',
        'wrapper' => 'embedding-dimension-wrapper',
        'event' => 'change',
      ],
    ];

    $form['embedding_settings']['embeddings_engine_configuration'] = [
      '#type' => 'fieldset',
      '#title' => t('Embedding Engine Configuration'),
      '#tree' => TRUE,
      '#prefix' => '<div id="embedding-dimension-wrapper">',
      '#suffix' => '</div>',
    ];

    $form['embedding_settings']['embeddings_engine_configuration']['dimension'] = [
      '#type' => 'textfield',
      '#title' => t('Embedding Dimension'),
      '#default_value' => $dimension_value,
      '#description' => t('The number of dimensions for embeddings.'),
    ];

    // Refresh embedding settings area when server changes.
    if (isset($form['server'])) {
      $form['server']['#ajax'] = [
        'callback' => 'search_api_ai_server_selection_callback',
        'wrapper' => 'edit-wrapper',
        'method' => 'replace',
      ];
    }

    // Persist embedding_settings into index options.
    if (empty($form['#submit']) || !in_array('search_api_ai_embedding_settings_submit', $form['#submit'], TRUE)) {
      $form['#submit'][] = 'search_api_ai_embedding_settings_submit';
    }
    if (empty($form['#after_build']) || !in_array('search_api_ai_embedding_settings_copy_for_save', $form['#after_build'], TRUE)) {
      $form['#after_build'][] = 'search_api_ai_embedding_settings_copy_for_save';
    }
  }
}

/**
 * Tiny helper to fetch nested value without notices.
 */
function _search_api_ai_nested_value(&$array, $keys) {
  $ref = &$array;
  foreach ($keys as $k) {
    if (!is_array($ref) || !array_key_exists($k, $ref)) {
      return NULL;
    }
    $ref = &$ref[$k];
  }
  return $ref;
}

/**
 * Server-side validate for embedding strategy fields.
 * Works for both add/edit because fields live in options][form][embedding_strategy].
 */
function search_api_ai_form_server_embedding_strategy_validate($form, &$form_state) {
  if (empty($form_state['values']['options']['form']['embedding_strategy'])) {
    return;
  }
  $vals = $form_state['values']['options']['form']['embedding_strategy'];

  if (isset($vals['chunk_size']) && (!is_numeric($vals['chunk_size']) || $vals['chunk_size'] <= 0)) {
    form_set_error('options][form][embedding_strategy][chunk_size', t('Chunk size must be a positive number.'));
  }
  if (isset($vals['chunk_overlap']) && (!is_numeric($vals['chunk_overlap']) || $vals['chunk_overlap'] < 0)) {
    form_set_error('options][form][embedding_strategy][chunk_overlap', t('Chunk overlap must be a non-negative number.'));
  }
}

/**
 * AJAX callback for server selection (index forms).
 */
function search_api_ai_server_selection_callback($form, &$form_state) {
  return $form['embedding_settings'];
}

/**
 * AJAX Callback to update embedding dimension dynamically (index forms).
 */
function search_api_ai_update_embedding_dimension($form, &$form_state) {
  $selected_engine = $form_state['values']['embedding_settings']['embeddings_engine'] ?? NULL;
  $dimension_value = 768; // Default

  $all_engines = module_invoke_all('embedding_engine_info');
  if ($selected_engine && isset($all_engines[$selected_engine])) {
    $engine_class = $all_engines[$selected_engine]['class'];
    if (class_exists($engine_class)) {
      try {
        // Create engine instance with NULL client - we only need getDimension()
        // which doesn't require a live API connection
        $engine_instance = new $engine_class([], NULL);

        if (method_exists($engine_instance, 'getDimension')) {
          $dimension_value = $engine_instance->getDimension();
        }
      } catch (Exception $e) {
        watchdog('search_api_ai', 'Failed to update dimension for @engine: @message', [
          '@engine' => $selected_engine,
          '@message' => $e->getMessage(),
        ], WATCHDOG_ERROR);
      }
    }
  }

  $form['embedding_settings']['embeddings_engine_configuration']['dimension']['#value'] = $dimension_value;
  return $form['embedding_settings']['embeddings_engine_configuration'];
}

/**
 * After-build: copy our embedding_settings into options for persistence (index).
 */
function search_api_ai_embedding_settings_copy_for_save($form, &$form_state) {
  if (!empty($form_state['values']['embedding_settings'])) {
    $form_state['values']['options']['embedding_settings'] = $form_state['values']['embedding_settings'];
  }
  return $form;
}

/**
 * Submit: ensure embedding_settings end up in options (index).
 */
function search_api_ai_embedding_settings_submit($form, &$form_state) {
  if (!empty($form_state['values']['embedding_settings'])) {
    $form_state['values']['options']['embedding_settings'] = $form_state['values']['embedding_settings'];
  }
}

/**
 * Submit handler for the legacy global engine config form (kept intact).
 */
function search_api_ai_embedding_engine_config_form_submit($form, &$form_state) {
  $selected_engine = $form_state['values']['options']['embeddings_engine'] ?? '';
  $engine_config = $form_state['values']['options']['embeddings_engine_configuration'] ?? ['dimension' => 768];

  $all_engines = module_invoke_all('embedding_engine_info');

  if ($selected_engine && isset($all_engines[$selected_engine])) {
    $engine_class = $all_engines[$selected_engine]['class'];

    if (class_exists($engine_class)) {
      try {
        $api_key_name = config_get('openai.settings', 'api_key');
        $api_key = key_get_key_value($api_key_name);
        if (!$api_key) {
          throw new Exception('OpenAI API key is missing.');
        }

        $client = new OpenAIApi($api_key);
        $engine_instance = new $engine_class(config_get('search_api_ai.settings'), $client);

        $model_name = method_exists($engine_instance, 'getModelName')
          ? $engine_instance->getModelName()
          : $selected_engine;

        if (method_exists($engine_instance, 'getDimension')) {
          $engine_config['dimension'] = $engine_instance->getDimension();
        }
      } catch (Exception $e) {
        backdrop_set_message(t('Failed to load embedding engine: @message', [
          '@message' => $e->getMessage(),
        ]), 'error');
        watchdog('search_api_ai', 'Error initializing embedding engine @engine: @message', [
          '@engine' => $selected_engine,
          '@message' => $e->getMessage(),
        ], WATCHDOG_ERROR);
      }
    }
  }

  // Persist legacy/global config (separate from per-index settings).
  config_set('search_api_ai.settings', 'embeddings_engine', $model_name);
  config_set('search_api_ai.settings', 'embeddings_engine_configuration', $engine_config);

  backdrop_set_message(t('Embedding engine configuration has been saved.'));
}

/**
 * Inject embeddings while indexing.
 */
/**
 * Inject embeddings while indexing.
 */
function search_api_ai_search_api_index_items_alter(array &$items, SearchApiIndex $index) {
  global $search_api_ai_vectors;
  if (!isset($search_api_ai_vectors)) $search_api_ai_vectors = [];

  watchdog('search_api_ai', '🔄 Altering index items for @index', [
    '@index' => $index->machine_name
  ], WATCHDOG_NOTICE);

  $query = db_select('search_api_index', 's')
    ->fields('s', ['options'])
    ->condition('machine_name', $index->machine_name)
    ->execute()
    ->fetchField();
  if (!$query) {
    watchdog('search_api_ai', "❌ Could not load index configuration.", [], WATCHDOG_ERROR);
    return;
  }
  $index_options = @unserialize($query);
  if (empty($index_options['fields']) || !is_array($index_options['fields'])) {
    watchdog('search_api_ai', "❌ No valid fields found in index configuration.", [], WATCHDOG_ERROR);
    return;
  }

  $embedding_settings = $index_options['embedding_settings'] ?? [];
  if (!is_array($embedding_settings)) $embedding_settings = [];

  $main_content_field = NULL;
  foreach ($index_options['fields'] as $field_name => $field_info) {
    if (!empty($field_info['real_type']) && $field_info['real_type'] === 'llm_vector_embedding') {
      $main_content_field = $field_name;
      break;
    }
  }
  if (!$main_content_field) {
    watchdog('search_api_ai', "❌ No field with llm_vector_embedding found. Nothing to embed.", [], WATCHDOG_ERROR);
    return;
  }

  $contextual_fields = array_diff(array_keys($index_options['fields']), [$main_content_field]);

  $view_mode = 'full';
  if (!empty($index_options['data_alter_callbacks']['search_api_alter_add_viewed_entity']['settings']['mode'])) {
    $view_mode = $index_options['data_alter_callbacks']['search_api_alter_add_viewed_entity']['settings']['mode'];
  }
  $expected_dimension = $embedding_settings['embeddings_engine_configuration']['dimension'] ?? 1536;

  foreach ($items as $id => $item) {
    $entity_type = NULL; $entity_id = NULL; $entity = NULL;
    if (is_string($id) && strpos($id, '/') !== FALSE) {
      list($entity_type, $entity_id) = explode('/', $id, 2);
      $entity = entity_load($entity_type, $entity_id);
    }
    elseif (is_object($item)) {
      if (isset($item->nid))            { $entity_type = 'node';             $entity_id = $item->nid; $entity = $item; }
      elseif (isset($item->tid))        { $entity_type = 'taxonomy_term';    $entity_id = $item->tid; $entity = $item; }
      elseif (isset($item->item_id))    { $entity_type = 'paragraphs_item';  $entity_id = $item->item_id; $entity = $item; }
    }
    if (!$entity || !$entity_type || !$entity_id) {
      watchdog('search_api_ai', '⚠️ Could not determine or load entity for ID: @id', ['@id' => $id], WATCHDOG_WARNING);
      continue;
    }

    $title = '';
    if ($entity_type == 'node' && !empty($entity->title)) {
      $title = $entity->title;
    }
    elseif ($entity_type == 'taxonomy_term' && !empty($entity->name)) {
      $title = $entity->name;
    }
    elseif ($entity_type == 'paragraphs_item' && !empty($entity->title)) {
      $title = $entity->title;
    }

    $context_metadata = ['title' => $title];
    foreach ($contextual_fields as $field_name) {
      if (!empty($entity->{$field_name})) {
        $value = $entity->{$field_name};
        if (is_array($value) && isset($value['und']) && is_array($value['und'])) {
          $tids = [];
          $labels = [];
          foreach ($value['und'] as $it) {
            if (!empty($it['tid'])) {
              $tids[] = $it['tid'];
              $term = taxonomy_term_load($it['tid']);
              if ($term && !empty($term->name)) {
                $labels[] = $term->name;
              }
            }
          }
          $context_metadata[$field_name . '_tids'] = $tids;
          $context_metadata[$field_name . '_names'] = $labels;
        }
        else {
          $context_metadata[$field_name] = $value;
        }
      }
    }

    $relative_url = '';
    $absolute_url = '';
    if ($entity_type === 'node') {
      $internal_path = "node/$entity_id";
      $path  = path_load(['source' => $internal_path]);
      $alias = !empty($path['alias']) ? $path['alias'] : $internal_path;
      $relative_url = $alias;
      $absolute_url = url($internal_path, ['absolute' => TRUE]);
    }
    elseif ($entity_type === 'taxonomy_term') {
      $internal_path = "taxonomy/term/$entity_id";
      $path  = path_load(['source' => $internal_path]);
      $alias = !empty($path['alias']) ? $path['alias'] : $internal_path;
      $relative_url = $alias;
      $absolute_url = url($internal_path, ['absolute' => TRUE]);
    }
    $context_metadata['search_api_url'] = $relative_url;
    $context_metadata['url'] = $absolute_url;

    $cleaned_text = '';
    if ($main_content_field == 'search_api_viewed') {
      $view = entity_view($entity, $view_mode);
      $cleaned_text = trim(strip_tags(render($view)));
    }
    else {
      if (!empty($entity->{$main_content_field})) {
        $field_value = $entity->{$main_content_field};
        if (is_array($field_value)) {
          foreach ($field_value as $langcode => $items2) {
            foreach ($items2 as $item_value) {
              if (!empty($item_value['value'])) {
                $cleaned_text .= "\n" . trim(strip_tags($item_value['value']));
              }
            }
          }
        } elseif (is_string($field_value)) {
          $cleaned_text = trim(strip_tags($field_value));
        }
      }
    }
    if (empty($cleaned_text)) {
      watchdog('search_api_ai', "⚠️ No main content to embed for $entity_type/$entity_id", [], WATCHDOG_WARNING);
      continue;
    }

    $vectors = search_api_ai_convert_embedding($cleaned_text, 'string', 'llm_vector_embedding', $embedding_settings, $main_content_field);

    foreach ($vectors as $chunk_idx => $entry) {
      $chunk_vector = $entry['vector'];
      $chunk_text   = $entry['chunk'];
      if (!is_array($chunk_vector) || count($chunk_vector) !== (int) $expected_dimension) {
        watchdog('search_api_ai', "❌ Invalid vector size for $main_content_field in entity $entity_type/$entity_id (chunk $chunk_idx)", [], WATCHDOG_ERROR);
        continue;
      }
      $search_api_ai_vectors[] = array_merge([
        'entity_type' => $entity_type,
        'entity_id'   => $entity_id,
        'field_name'  => $main_content_field,
        'chunk_index' => $chunk_idx,
        'vector'      => $chunk_vector,
        'content'     => $chunk_text,
      ], $context_metadata);
    }
  }

  watchdog('search_api_ai', '✅ Finished altering index items for @index', [
    '@index' => $index->machine_name
  ], WATCHDOG_NOTICE);
}

/**
 * Processor definition for boosting DB results with AI search.
 */
function search_api_ai_search_api_processor_info() {
  return [
    'database_boost_by_ai_search' => [
      'name' => t('Boost Database by AI Search'),
      'description' => t('Prepends vector DB results to the traditional database results while respecting filters and facets.'),
      'class' => 'DatabaseBoostByAiSearch',
    ],
  ];
}

/**
 * Alters DB query with AI search IDs when present.
 */
function search_api_ai_search_api_db_query_alter(SelectQueryInterface $query, SearchApiQueryInterface $search_api_query) {
  $item_ids = $search_api_query->getOption('ai_search_ids');
  if (!empty($item_ids)) {
    DatabaseBoostByAiSearch::queryAlter($query, $item_ids);
  }
}
