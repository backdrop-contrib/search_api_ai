}

/**
 * Implements hook_search_api_data_type_info().
 */
function search_api_ai_search_api_data_type_info() {
  return array(
    'llm_vector_embedding' => array(
      'name' => t('Embeddings'),
      'fallback' => 'string', // Falls back to string if unsupported by the backend.
      'conversion callback' => 'search_api_ai_convert_embedding',
    ),
  );
}

function search_api_ai_get_embedding_dimension() {
  $search_api_ai_config = config('search_api_ai.settings');

  $embedding_config = $search_api_ai_config->get('embeddings_engine_configuration') ?? [];

  // Ensure we are correctly retrieving the dimension
  watchdog('search_api_ai', '🔍 Retrieved embedding dimension from config: @dimension', [
    '@dimension' => isset($embedding_config['dimension']) ? $embedding_config['dimension'] : 'MISSING',
  ], WATCHDOG_DEBUG);

  return (int) ($embedding_config['dimension'] ?? 1536);
}


function search_api_ai_convert_embedding($value, $original_type, $type, array
$embedding_settings, $field_name = 'unknown_field') {
  if ($type !== 'llm_vector_embedding' || !is_string($value)) {
    watchdog('search_api_ai', "❌ Bad call: type=$type, is_string=" . (is_string($value) ? 'yes' : 'no'), [], WATCHDOG_WARNING);
    return [];
  }

  $prepared_text = StringHelper::prepareText($value);
  if (empty($prepared_text)) {
    watchdog('search_api_ai', "⚠️ Skipping empty text for field: $field_name", [], WATCHDOG_WARNING);
    return [];
  }

  $chunk_size    = 500;
  $chunk_overlap = 100;
  $chunks = TextChunker::chunkText($prepared_text, $chunk_size, $chunk_overlap);
  //dpm($chunks);

  $config = search_api_ai_get_embedding_engine_config($embedding_settings);
  $model = $config['engine'];
  $expected_dimension = $config['dimension'];

  if (empty($model)) {
    watchdog('search_api_ai', "❌ No valid embeddings model set.", [], WATCHDOG_ERROR);
    return [];
  }

  $openai_config = config('openai.settings');
  $api_key_name  = $openai_config->get('api_key');
  $api_key       = key_get_key_value($api_key_name);
  $openai_api    = new OpenAIApi($api_key);

  // Instead of just $vectors[], build an array of ['vector' => ..., 'chunk' => ...]
  $chunked_vectors = [];
  foreach ($chunks as $i => $chunk) {
    $chunk_clean = StringHelper::prepareText($chunk);
    if (empty($chunk_clean)) continue;
    try {
      $vector = $openai_api->embedding($chunk_clean, $model);
      if (!is_array($vector) || count($vector) !== (int)$expected_dimension) {
        watchdog('search_api_ai', "❌ Invalid chunk vector size for $field_name: Expected $expected_dimension, got " . (is_array($vector) ? count($vector) : gettype($vector)), [], WATCHDOG_ERROR);
        continue;
      }
      $chunked_vectors[] = [
        'vector' => $vector,
        'chunk'  => $chunk, // keep original, not cleaned, so you can display!
      ];
    } catch (Exception $e) {
      watchdog('search_api_ai', "❌ OpenAI API error for $field_name: " . $e->getMessage(), [], WATCHDOG_ERROR);
    }
  }
  if (empty($chunked_vectors)) {
    watchdog('search_api_ai', "⚠️ No valid vectors generated for $field_name", [], WATCHDOG_WARNING);
  }
  return $chunked_vectors;
}


/**
 * Get embedding model and dimension from Search API AI index options.
 *
 * @param array $embedding_settings
 *   The index-specific embedding_settings array.
 * @return array
 *   Array with 'engine' and 'dimension'.
 */
function search_api_ai_get_embedding_engine_config(array $embedding_settings) {
  if (empty($embedding_settings['embeddings_engine'])) {
    throw new Exception('No embedding engine set in index options.');
  }
  $model = $embedding_settings['embeddings_engine'];
  $dimension = isset($embedding_settings['embeddings_engine_configuration']['dimension'])
    ? (int) $embedding_settings['embeddings_engine_configuration']['dimension']
    : 1536; // Or maybe throw if you want to enforce explicit config

  return [
    'engine' => $model,
    'dimension' => $dimension,
  ];
}


/**
 * Implements hook_init().
 *
 * Initializes the plugin manager and stores it globally.
 */
function search_api_ai_init() {
  // Instantiate the plugin manager.
  $plugin_manager = new EmbeddingEnginePluginManager();

  // Instantiate the static helper class, passing the plugin manager.
  $embedding_engine_static = new EmbeddingEngineStatic($plugin_manager);

  // Store it in a global variable if needed.
  $GLOBALS['search_api_ai']['embedding_engine_static'] = $embedding_engine_static;
}


