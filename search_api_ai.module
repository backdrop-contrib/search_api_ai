  return [
    'openai' => [
      'label' => t('OpenAI Embeddings'),
      'class' => 'OpenAiEmbeddingsDefault',
    ],
    'pinecone' => [
      'label' => t('Pinecone Vector Store'),
      'class' => 'PineconeVectorClient',
    ],
